<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Unit Converter</title>
    <link rel="stylesheet" href="../Style/stylesheet.css">
    <!-- <script src="main.js" defer></script> -->
</head>
<body>
    <div class="settings">
        <header>
            <h1 id="Title">Unit Converter</h1>
            <div class="unitsTabs">
                <button id="lengthButton"><a href="length.html" id="selectedTab">Length</a></button>
                <button id="weightButton"><a href="weight.html">Weight</a></button>
                <button id="temperatureButton"><a href="temperature.html">Temperature</a></button>
            </div>
        </header>
        <main>
            <form action="/convert-length" method="get" target="_self" class="lengthForm">
                <div class="textInput">
                    <label for="unitDigits">Enter the length to convert</label>
                    <input type="number" name="unitDigits" id="unitDigits">
                </div>
                <div class="textInput">
                    <label for="unitConvertFrom">Unit to Convert from</label>
                    <select name="unitConvertFrom" id="unitConvertFrom">
                        <option></option>
                        <option value="mm">Millimeters</option>
                        <option value="cm">Centimeters</option>
                        <option value="m">Meters</option>
                        <option value="km">Kilometers</option>
                        <option value="in">Inches</option>
                        <option value="ft">Feet</option>
                        <option value="yd">Yards</option>
                        <option value="mi">Miles</option>
                    </select>
                </div>
                <div class="textInput">
                    <label for="unitConvertTo">Unit to Convert to</label>
                    <select name="unitConvertTo" id="unitConvertTo">
                        <option></option>
                        <option value="mm">Millimeters</option>
                        <option value="cm">Centimeters</option>
                        <option value="m">Meters</option>
                        <option value="km">Kilometers</option>
                        <option value="in">Inches</option>
                        <option value="ft">Feet</option>
                        <option value="yd">Yards</option>
                        <option value="mi">Miles</option>
                    </select>
                </div>
                <input id="endButton" type="submit" value="Convert">
            </form>
            <div class="resultBox close">
                <p>Result of your calculation</p>
                <p id="resultText">20ft = 1000cm</p>
                <button id="resetButton">Reset</button>
            </div>
        </main>
    </div>
</body>
</html>